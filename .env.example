# para-files Configuration
# Copy this file to .env and adjust values as needed

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# Root directory containing PARA folders (0_Inbox, 1_Projects, 2_Areas, etc.)
PARA_FILES_PARA_ROOT=/Users/you/Documents/PARA

# =============================================================================
# REFERENCE TREE
# =============================================================================

# Path to the PARA reference tree YAML file
# Contains: folder structure, semantic utterances, routing rules, known issuers
PARA_FILES_REFERENCE_TREE_PATH=config/personal_file_tree.yaml

# Path to validated sender→category mappings JSON (optional)
# Format: {"sender@domain.com": "2_Areas/Finance/Banque"}
# PARA_FILES_VALIDATED_DB_PATH=/path/to/validated_mappings.json

# =============================================================================
# MLX EMBEDDING MODEL
# =============================================================================

# MLX embedding model from Hugging Face (loaded lazily on first use)
# Default: mlx-community/nomic-embed-text-v1.5 (~100MB, cached in ~/.cache/huggingface)
PARA_FILES_MLX_MODEL_NAME=mlx-community/nomic-embed-text-v1.5

# Minimum cosine similarity score for semantic matching (0.0 to 1.0)
# Higher = stricter matching, fewer false positives but more fallback to inbox
PARA_FILES_MLX_SCORE_THRESHOLD=0.75

# =============================================================================
# LLM FALLBACK (Optional)
# =============================================================================

# Enable LLM fallback for ambiguous classifications
# When enabled, files that don't match any signal will be sent to the LLM
PARA_FILES_LLM_ENABLED=false

# LLM model identifier (litellm format)
# Examples: ollama/qwen2.5:1.5b, openai/gpt-4o-mini, anthropic/claude-3-haiku
PARA_FILES_LLM_MODEL=ollama/qwen2.5:1.5b

# Minimum confidence from LLM to accept classification (0.0 to 1.0)
PARA_FILES_LLM_CONFIDENCE_THRESHOLD=0.6

# API base URL for Ollama or other local providers
# For Ollama: http://localhost:11434
# PARA_FILES_LLM_API_BASE=http://localhost:11434

# =============================================================================
# CONTENT EXTRACTION
# =============================================================================

# Number of characters to extract from files for semantic matching
# Larger values provide more context but increase processing time
PARA_FILES_CONTENT_PREVIEW_CHARS=2000
