# para-files Configuration
# Copy this file to .env and adjust values as needed.
#
# Global config location: ~/.config/para-files/.env
#   Place settings there to apply regardless of which directory you invoke para-files from.
#   A local .env in the current directory takes precedence over the global config.

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# Root directory containing PARA folders (0_Inbox, 1_Projects, 2_Areas, etc.)
PARA_FILES_PARA_ROOT=/Users/you/Documents/PARA

# =============================================================================
# REFERENCE TREE
# =============================================================================

# Path to the PARA reference tree YAML file
# Contains: folder structure, semantic utterances, routing rules, known issuers
PARA_FILES_REFERENCE_TREE_PATH=config/personal_file_tree.yaml

# Path to validated sender→category mappings JSON (optional)
# Format: {"sender@domain.com": "2_Areas/Finance/Banque"}
# PARA_FILES_VALIDATED_DB_PATH=/path/to/validated_mappings.json

# =============================================================================
# OLLAMA EMBEDDING MODEL
# =============================================================================

# Embedding model name served by local Ollama (called via litellm)
# Default: nomic-text-v1.5 (768 dims)
PARA_FILES_MLX_MODEL_NAME=nomic-text-v1.5

# Minimum cosine similarity score for semantic matching (0.0 to 1.0)
# Higher = stricter matching, fewer false positives but more fallback to inbox
PARA_FILES_MLX_SCORE_THRESHOLD=0.75

# Minimum cosine similarity for SemanticClassifier to accept a category match.
# Default 0.65 works well for nomic-embed-text (typical good match: 0.65–0.75).
PARA_FILES_MLX_SEMANTIC_THRESHOLD=0.65

# =============================================================================
# LLM FALLBACK (litellm — enabled by default)
# =============================================================================

# Enable LLM fallback for ambiguous classifications (last-resort before 0_Inbox)
PARA_FILES_LLM_ENABLED=true

# LLM model identifier in litellm format
# --- Local Ollama ---
PARA_FILES_LLM_MODEL=ollama/ministral-3:8b
# PARA_FILES_LLM_API_BASE=http://localhost:11434

# --- OpenRouter (cloud LLM, no local Ollama required for LLM fallback) ---
# PARA_FILES_LLM_MODEL=openrouter/mistralai/mistral-small-2603
# PARA_FILES_LLM_API_BASE=https://openrouter.ai/api/v1
# PARA_FILES_LLM_API_KEY=sk-or-v1-your-key-here

# --- OpenAI ---
# PARA_FILES_LLM_MODEL=openai/gpt-4o-mini
# PARA_FILES_LLM_API_KEY=sk-your-openai-key-here

# Minimum confidence from LLM to accept classification (0.0 to 1.0)
PARA_FILES_LLM_CONFIDENCE_THRESHOLD=0.6

# Request timeout in seconds (increase for slower models)
# PARA_FILES_LLM_TIMEOUT=15.0

# =============================================================================
# CONTENT EXTRACTION
# =============================================================================

# Number of characters to extract from files for semantic matching
# Larger values provide more context but increase processing time
PARA_FILES_CONTENT_PREVIEW_CHARS=2000

# =============================================================================
# EXTENSION ROUTING
# =============================================================================

# Fallback destination for files with unrecognised extensions.
# Must be a folder that actually exists under PARA_ROOT.
# PARA_FILES_EXT_ROUTING_CATCHALL_FOLDER=0_Inbox
